{
	"editor.tabSize": 2,
	"editor.detectIndentation": false,
  "importSorter.importStringConfiguration.quoteMark": "double",
  "importSorter.sortConfiguration.customOrderingRules.rules": [
    {
        "type": "importMember",
        "regex": "^$",
        "orderLevel": 10,
        "disableSort": true
    },
    {
        "regex": "@angular",
        "orderLevel": 20
    },
    {
      "regex": "rxjs|ngx",
      "orderLevel": 30
    },
    {
      "regex": "@environment",
      "orderLevel": 40
    },
    {
      "regex": "^[.]",
      "orderLevel": 50
    },
  ]
}